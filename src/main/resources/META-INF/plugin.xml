<idea-plugin>
    <id>com.translator</id>
    <name>TranslatorPluginJava2026</name>
    <vendor>matio004</vendor>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <applicationService serviceImplementation="com.translator.AppSettingsState"/>
        <applicationService serviceImplementation="com.translator.GroqTranslationService"/>

        <applicationConfigurable parentId="tools"
                                 instance="com.translator.AppSettingsConfigurable"
                                 id="com.translator.AppSettingsConfigurable"
                                 displayName="Translation Plugin Settings"/>

        <externalAnnotator language="JAVA" implementationClass="com.translator.TranslationAnnotator"/>
        <externalAnnotator language="kotlin" implementationClass="com.translator.TranslationAnnotator"/>
    </extensions>
</idea-plugin>